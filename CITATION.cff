title: >-
  CalDraCor (Calderón Drama Corpus): TEI-encoded corpus of
  205 plays by Pedro Calderón de la Barca
message: "If you use this corpus, please cite it as below."
type: dataset

authors:
  - given-names: Hanno
    family-names: Ehrlicher
    affiliation: University of Tübingen
    orcid: "https://orcid.org/0000-0002-4185-1310"
  - given-names: Simon
